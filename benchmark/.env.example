# CERN GitLab MCP Server Configuration
# Copy this file to .env and adjust as needed.

# =============================================================================
# GitLab Configuration
# =============================================================================

# GitLab instance URL (default: https://gitlab.cern.ch)
# CERNGITLAB_GITLAB_URL=https://gitlab.cern.ch

# Personal access token (optional — public repos work without it)
# Create at: https://gitlab.cern.ch/-/user_settings/personal_access_tokens
# Required scope: read_api
# CERNGITLAB_TOKEN=glpat-xxxxxxxxxxxx

# HTTP timeout in seconds (default: 30)
# CERNGITLAB_TIMEOUT=30

# Max retries for failed requests (default: 3)
# CERNGITLAB_MAX_RETRIES=3

# API rate limit per minute (default: 30)
# CERNGITLAB_RATE_LIMIT_PER_MINUTE=30

# Logging level: DEBUG, INFO, WARNING, ERROR (default: INFO)
# CERNGITLAB_LOG_LEVEL=INFO

# =============================================================================
# Benchmark Configuration (for running benchmarks)
# =============================================================================

# LiteLLM API Key from CERN (REQUIRED for benchmarks)
# Get from CERN LLM platform
# CERNGITLAB_LITELLM_API_KEY=your-litellm-api-key

# GitLab Personal Access Token (REQUIRED for benchmarks)
# CERNGITLAB_GITLAB_TOKEN=glpat-xxxxxxxxxxxx

# LiteLLM API base URL (default: https://llmgw-litellm.web.cern.ch/v1)
# CERNGITLAB_LITELLM_BASE=https://llmgw-litellm.web.cern.ch/v1

# Model to use for benchmarks (default: gpt-5.2)
# CERNGITLAB_LITELLM_MODEL=gpt-5.2

# LLM API timeout in seconds (default: 120)
# CERNGITLAB_LLM_TIMEOUT=120

# GitLab API timeout in seconds (default: 60)
# CERNGITLAB_GITLAB_TIMEOUT=60

# Session timeout per question in seconds (default: 300)
# CERNGITLAB_SESSION_TIMEOUT=300

# Max retry attempts for API calls (default: 3)
# CERNGITLAB_MAX_RETRIES=3

# Delay between retries in seconds (default: 2.0)
# CERNGITLAB_RETRY_DELAY=2.0
